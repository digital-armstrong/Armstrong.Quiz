<div data-option-row class="card bg-base-200 p-4 rounded-lg flex flex-col gap-3">
  <div class="flex justify-between items-start gap-2">
    <span class="text-sm font-medium text-base-content/70"><%= t("admin.answer_options.option") %> <%= f.object.persisted? ? f.object.position : "-" %></span>
    <% if f.object.persisted? %>
      <%= f.hidden_field :_destroy, value: "0", data: { destroy_field: true } %>
      <button type="button" class="btn btn-ghost btn-xs text-error" onclick="this.closest('[data-option-row]').querySelector('[data-destroy-field]').value='1'; this.closest('[data-option-row]').style.display='none';">
        <%= t("admin.answer_options.remove") %>
      </button>
    <% else %>
      <button type="button" class="btn btn-ghost btn-xs text-error" onclick="this.closest('[data-option-row]').remove()">
        <%= t("admin.answer_options.remove") %>
      </button>
    <% end %>
  </div>
  <div class="form-control">
    <label class="label py-0"><span class="label-text"><%= t("admin.answer_options.body") %></span></label>
    <%= f.text_area :body, rows: 2, class: "textarea textarea-bordered w-full text-sm", placeholder: t("admin.answer_options.body_placeholder") %>
  </div>
  <label class="label cursor-pointer justify-start gap-2 py-0">
    <%= f.check_box :correct, class: "checkbox checkbox-primary checkbox-sm" %>
    <span class="label-text"><%= t("admin.answer_options.correct") %></span>
  </label>
  <%= f.hidden_field :position if f.object.persisted? %>
</div>
