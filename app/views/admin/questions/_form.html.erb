<%= form_with model: question, url: url, class: "space-y-4" do |f| %>
  <%= render "shared/error_messages", resource: question %>
  <div class="form-control">
    <%= f.label :category_id, class: "label" %>
    <%= f.collection_select :category_id, @categories, :id, :title, {}, class: "select select-bordered w-full" %>
  </div>
  <div class="form-control">
    <%= f.label :title, class: "label" %>
    <%= f.text_field :title, class: "input input-bordered w-full" %>
  </div>
  <div class="form-control">
    <%= f.label :body, class: "label" %>
    <%= f.text_area :body, rows: 6, class: "textarea textarea-bordered w-full font-mono text-sm" %>
  </div>

  <fieldset class="form-control border border-base-300 rounded-box p-4">
    <legend class="text-sm font-semibold px-1"><%= Question.human_attribute_name(:pool_tag) %></legend>
    <p class="text-sm text-base-content/60 mb-3"><%= t("admin.questions.pool_tag_hint") %></p>
    <div class="flex flex-col gap-2">
      <% Question.pool_tags.keys.each do |tag| %>
        <label class="label cursor-pointer justify-start gap-3 py-1">
          <%= f.radio_button :pool_tag, tag, class: "radio radio-primary" %>
          <span class="label-text"><%= Question.human_pool_tag_name(tag) %></span>
        </label>
      <% end %>
    </div>
  </fieldset>

  <div class="form-control">
    <label class="label cursor-pointer justify-start gap-3 py-2 rounded-lg border border-base-300 px-3">
      <%= f.check_box :multiple_answers, class: "checkbox checkbox-primary" %>
      <span class="label-text"><%= Question.human_attribute_name(:multiple_answers) %></span>
    </label>
    <p class="text-sm text-base-content/60 pl-1"><%= t("admin.questions.multiple_answers_hint") %></p>
  </div>

  <div class="form-control pt-4 border-t border-base-300" data-controller="answer-options" data-answer-options-url-value="<%= new_option_fields_admin_questions_path %>">
    <div class="flex items-center justify-between mb-2">
      <label class="label py-0"><span class="label-text font-semibold"><%= t("admin.answer_options.index_title") %></span></label>
      <button type="button" class="btn btn-outline btn-sm" data-action="click->answer-options#add" data-answer-options-target="addButton">
        <%= t("admin.answer_options.add") %>
      </button>
    </div>
    <div id="answer_options_container" class="space-y-3" data-answer-options-target="container">
      <%= f.fields_for :answer_options do |opt_f| %>
        <%= render "answer_option_fields_form", f: opt_f %>
      <% end %>
    </div>
  </div>

  <%= f.submit (question.persisted? ? t("admin.actions.update") : t("admin.actions.create")), class: "btn btn-primary" %>
<% end %>
