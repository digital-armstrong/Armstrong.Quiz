<div class="flex justify-between items-center mb-6">
  <h1 class="text-3xl font-bold"><%= @category.title %></h1>
  <div class="flex gap-2">
    <%= link_to t("admin.actions.edit"), edit_admin_category_path(@category), class: "btn btn-primary" %>
    <%= link_to t("admin.actions.back"), admin_categories_path, class: "btn btn-ghost" %>
  </div>
</div>

<div class="card bg-base-100 shadow-xl">
  <div class="card-body">
    <% if @category.description.present? %>
      <div class="markdown"><%= markdown(@category.description) %></div>
    <% end %>
    <p class="text-sm text-base-content/70"><%= @category.questions.count %> <%= t("admin.categories.questions_count") %></p>
  </div>
</div>
