<%= form_with model: category, url: url, class: "space-y-4" do |f| %>
  <%= render "shared/error_messages", resource: category %>
  <div class="form-control">
    <%= f.label :section_id, class: "label" %>
    <%= f.collection_select :section_id, Section.order(:title), :id, :title, {}, class: "select select-bordered w-full" %>
  </div>
  <div class="form-control">
    <%= f.label :title, class: "label" %>
    <%= f.text_field :title, class: "input input-bordered w-full" %>
  </div>
  <div class="form-control">
    <%= f.label :description, class: "label" %>
    <%= f.text_area :description, rows: 4, class: "textarea textarea-bordered w-full" %>
  </div>
  <%= f.submit (category.persisted? ? t("admin.actions.update") : t("admin.actions.create")), class: "btn btn-primary" %>
<% end %>
