<div class="flex justify-between items-center mb-6">
  <h1 class="text-3xl font-bold"><%= t("admin.categories.index_title") %></h1>
  <%= link_to new_admin_category_path, class: "btn btn-primary gap-2" do %>
    <%= heroicon :plus, variant: :mini, options: { class: "w-4 h-4" } %>
    <span><%= t("admin.categories.new") %></span>
  <% end %>
</div>

<div class="overflow-x-auto bg-base-100 rounded-box shadow">
  <table class="table">
    <thead>
      <tr>
        <th><%= Category.human_attribute_name(:title) %></th>
        <th><%= Category.human_attribute_name(:description) %></th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @categories.each do |category| %>
        <tr class="hover:bg-base-200 transition-all duration-300 whitespace-nowrap">
          <td><%= category.title %></td>
          <td><%= truncate(category.description.to_s, length: 60) %></td>
          <td class="flex justify-end gap-2">
            <%= link_to admin_category_path(category), class: "btn btn-ghost btn-sm gap-1" do %>
              <%= heroicon :eye, variant: :mini, options: { class: "w-4 h-4" } %>
              <span><%= t("admin.actions.show") %></span>
            <% end %>
            <%= link_to edit_admin_category_path(category), class: "btn btn-ghost btn-sm gap-1" do %>
              <%= heroicon :pencil, variant: :mini, options: { class: "w-4 h-4" } %>
              <span><%= t("admin.actions.edit") %></span>
            <% end %>
            <%= button_to admin_category_path(category), method: :delete,
                  form: { data: { turbo_confirm: t("admin.confirm_destroy") } },
                  class: "btn btn-ghost btn-sm text-error gap-1" do %>
              <%= heroicon :trash, variant: :mini, options: { class: "w-4 h-4" } %>
              <span><%= t("admin.actions.destroy") %></span>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
