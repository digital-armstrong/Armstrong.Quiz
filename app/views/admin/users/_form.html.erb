<%= form_with model: [:admin, user], class: "space-y-4" do |f| %>
  <%= render "shared/error_messages", resource: user %>
  <%= f.fields_for :profile, user.profile || user.build_profile do |pf| %>
    <div class="grid gap-4 sm:grid-cols-2">
      <div class="form-control">
        <%= pf.label :last_name, t("activerecord.attributes.profile.last_name"), class: "label" %>
        <%= pf.text_field :last_name, class: "input input-bordered w-full" %>
      </div>
      <div class="form-control">
        <%= pf.label :first_name, t("activerecord.attributes.profile.first_name"), class: "label" %>
        <%= pf.text_field :first_name, class: "input input-bordered w-full" %>
      </div>
    </div>
    <div class="form-control">
      <%= pf.label :middle_name, t("activerecord.attributes.profile.middle_name"), class: "label" %>
      <%= pf.text_field :middle_name, class: "input input-bordered w-full" %>
    </div>
  <% end %>
  <div class="form-control">
    <%= f.label :email, class: "label" %>
    <%= f.email_field :email, class: "input input-bordered w-full" %>
  </div>
  <div class="form-control">
    <%= f.label :password, class: "label" %>
    <%= f.password_field :password, class: "input input-bordered w-full", autocomplete: "new-password" %>
    <span class="label-text-alt text-base-content/60">
      <%= (user.new_record? ? t("admin.users.password_required_hint") : t("admin.users.password_optional_hint")) + " " + t("admin.users.password_min_hint", count: User.password_length.min) %>
    </span>
  </div>
  <div class="form-control">
    <%= f.label :password_confirmation, class: "label" %>
    <%= f.password_field :password_confirmation, class: "input input-bordered w-full", autocomplete: "new-password" %>
  </div>
  <div class="form-control">
    <%= f.label :role, t("admin.users.role"), class: "label" %>
    <%= f.select :role, User::ROLES.map { |r| [t("admin.users.roles.#{r}"), r] }, {}, class: "select select-bordered w-full" %>
  </div>
  <%= f.submit (user.persisted? ? t("admin.actions.update") : t("admin.actions.create")), class: "btn btn-primary" %>
<% end %>
