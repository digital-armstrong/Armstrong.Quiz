<div class="flex justify-between items-center mb-6">
  <h1 class="text-3xl font-bold"><%= @user.full_name %></h1>
  <div class="flex gap-2">
    <%= link_to t("admin.actions.edit"), edit_admin_user_path(@user), class: "btn btn-primary" %>
    <%= link_to t("admin.actions.back"), admin_users_path, class: "btn btn-ghost" %>
  </div>
</div>

<div class="card bg-base-100 shadow-xl">
  <div class="card-body">
    <p><strong><%= t("admin.users.email") %>:</strong> <%= @user.email %></p>
    <p><strong><%= t("admin.users.role") %>:</strong> <%= t("admin.users.roles.#{@user.role}") %></p>
    <p><strong><%= t("admin.users.state") %>:</strong> <%= t("admin.users.states.#{@user.state}") %></p>
    <% if @user.profile %>
      <p><strong><%= t("admin.users.name") %>:</strong> <%= @user.full_name %></p>
    <% end %>
  </div>
</div>

<div class="mt-4">
  <%= link_to t("admin.results.evaluate"), admin_new_user_evaluation_path(user_id: @user.id), class: "btn btn-primary" if @user.student? %>
  <%= link_to t("admin.actions.show") + " " + t("admin.nav.results"), admin_result_path(@user.id), class: "btn btn-ghost" if @user.student? %>
</div>
