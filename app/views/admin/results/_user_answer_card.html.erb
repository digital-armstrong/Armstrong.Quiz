<% q = ua.question %>
<div id="<%= dom_id(ua) %>" class="card bg-base-100 shadow scroll-mt-24">
  <div class="card-body">
    <div class="flex flex-wrap items-start justify-between gap-2 gap-y-2 mb-3">
      <h3 class="font-semibold text-lg flex-1 min-w-[12rem]"><%= q.title %></h3>
      <div class="flex flex-wrap gap-2 shrink-0">
        <% if q.answer_options.any? %>
          <% if ua.answer_option %>
            <% if ua.answer_option.correct? %>
              <span class="badge badge-success"><%= t("admin.dashboard.correct") %></span>
            <% else %>
              <span class="badge badge-error"><%= t("admin.dashboard.incorrect") %></span>
            <% end %>
          <% else %>
            <span class="badge badge-ghost"><%= t("admin.results.no_answer_selected") %></span>
          <% end %>
        <% elsif ua.admin_correct.nil? %>
          <span class="badge badge-info"><%= t("admin.results.awaiting_approval") %></span>
        <% elsif ua.admin_correct? %>
          <span class="badge badge-success"><%= t("admin.dashboard.correct") %></span>
        <% else %>
          <span class="badge badge-error"><%= t("admin.dashboard.incorrect") %></span>
        <% end %>
      </div>
    </div>

    <% if q.body.present? %>
      <div class="markdown text-sm mb-4"><%= markdown(q.body) %></div>
    <% end %>

    <% if q.answer_options.any? %>
      <p class="text-sm font-medium text-base-content/80 mb-2"><%= t("admin.results.answer_options_heading") %></p>
      <ul class="space-y-2">
        <% q.answer_options.each do |opt| %>
          <% chosen = ua.answer_option_id == opt.id %>
          <% row_border =
            if chosen && opt.correct?
              "border-2 border-success bg-success/5"
            elsif chosen && !opt.correct?
              "border-2 border-error bg-error/5"
            else
              "border border-base-300"
            end %>
          <li class="flex gap-3 items-start rounded-lg p-3 text-sm <%= row_border %>">
            <div class="shrink-0 w-8 flex flex-col items-center justify-start gap-0.5 pt-0.5" aria-hidden="true">
              <% if chosen && opt.correct? %>
                <%= heroicon "check-circle", variant: :mini, options: { class: "w-7 h-7 text-success" } %>
              <% elsif chosen && !opt.correct? %>
                <%= heroicon "x-circle", variant: :mini, options: { class: "w-7 h-7 text-error" } %>
              <% elsif opt.correct? %>
                <%= heroicon "check-circle", variant: :mini, options: { class: "w-7 h-7 text-success" } %>
              <% end %>
            </div>
            <div class="flex-1 min-w-0 markdown"><%= markdown(opt.body) %></div>
            <% if chosen %>
              <span class="badge badge-primary badge-sm shrink-0"><%= t("admin.results.student_choice") %></span>
            <% end %>
          </li>
        <% end %>
      </ul>
      <% if ua.comment.present? %>
        <p class="text-sm mt-4"><strong><%= t("admin.results.comment") %>:</strong></p>
        <div class="markdown text-sm mt-1"><%= markdown(ua.comment) %></div>
      <% end %>
    <% else %>
      <p class="text-sm"><strong><%= t("admin.results.answer_in_words") %>:</strong></p>
      <div class="markdown text-sm mt-1"><%= ua.comment.present? ? markdown(ua.comment) : "—" %></div>
      <% if ua.admin_correct.nil? %>
        <div class="flex gap-2 mt-4">
          <%= button_to t("admin.dashboard.correct"),
              admin_user_answer_path(ua),
              method: :patch,
              params: { user_answer: { admin_correct: true } },
              form: { data: { turbo: false } },
              class: "btn btn-success btn-sm" %>
          <%= button_to t("admin.dashboard.incorrect"),
              admin_user_answer_path(ua),
              method: :patch,
              params: { user_answer: { admin_correct: false } },
              form: { data: { turbo: false } },
              class: "btn btn-error btn-sm" %>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
