<%#
  Декоративная модель атома в фирменной сине-голубой палитре АО «ГНЦ НИИАР»
  (отраслевые цвета, согласованные с атомной отраслью / визуальной средой niiar.ru).
  locals: uid — уникальный id для градиентов; show_caption — подпись «ГНЦ НИИАР» (опционально)
%>
<% uid = local_assigns[:uid] || "atom" %>
<% show_caption = local_assigns[:show_caption] %>
<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 200 200"
  class="h-full w-full"
  role="img"
  aria-hidden="true"
  focusable="false"
>
  <defs>
    <linearGradient id="niiar-nucleus-<%= uid %>" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#1a9fd6"/>
      <stop offset="50%" stop-color="#0066b3"/>
      <stop offset="100%" stop-color="#004c97"/>
    </linearGradient>
    <linearGradient id="niiar-orbit-<%= uid %>" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" stop-color="#004c97" stop-opacity="0.15"/>
      <stop offset="50%" stop-color="#0090d8" stop-opacity="0.55"/>
      <stop offset="100%" stop-color="#004c97" stop-opacity="0.15"/>
    </linearGradient>
    <filter id="niiar-glow-<%= uid %>" x="-40%" y="-40%" width="180%" height="180%">
      <feGaussianBlur in="SourceGraphic" stdDeviation="1.2" result="blur"/>
      <feMerge>
        <feMergeNode in="blur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>
  <!-- орбиты: три эллипса под классическим углом 60° -->
  <ellipse
    cx="100"
    cy="100"
    rx="82"
    ry="34"
    fill="none"
    stroke="url(#niiar-orbit-<%= uid %>)"
    stroke-width="1.35"
    transform="rotate(0 100 100)"
  />
  <ellipse
    cx="100"
    cy="100"
    rx="82"
    ry="34"
    fill="none"
    stroke="#0066b3"
    stroke-opacity="0.42"
    stroke-width="1.2"
    transform="rotate(60 100 100)"
  />
  <ellipse
    cx="100"
    cy="100"
    rx="82"
    ry="34"
    fill="none"
    stroke="#0066b3"
    stroke-opacity="0.42"
    stroke-width="1.2"
    transform="rotate(120 100 100)"
  />
  <!-- внешнее кольцо-акцент -->
  <circle cx="100" cy="100" r="92" fill="none" stroke="#004c97" stroke-opacity="0.08" stroke-width="1"/>
  <!-- ядро -->
  <circle cx="100" cy="100" r="16" fill="url(#niiar-nucleus-<%= uid %>)" filter="url(#niiar-glow-<%= uid %>)"/>
  <circle cx="100" cy="100" r="22" fill="none" stroke="#0090d8" stroke-opacity="0.35" stroke-width="0.75"/>
  <!-- электроны -->
  <circle cx="182" cy="100" r="5.5" fill="#00b4e6" stroke="#004c97" stroke-opacity="0.35" stroke-width="0.5"/>
  <circle cx="59" cy="129" r="5.5" fill="#00b4e6" stroke="#004c97" stroke-opacity="0.35" stroke-width="0.5"/>
  <circle cx="59" cy="71" r="5.5" fill="#00b4e6" stroke="#004c97" stroke-opacity="0.35" stroke-width="0.5"/>
  <% if show_caption %>
    <text
      x="100"
      y="192"
      text-anchor="middle"
      font-family="ui-sans-serif, system-ui, sans-serif"
      font-size="10"
      font-weight="700"
      letter-spacing="0.25em"
      fill="#004c97"
      fill-opacity="0.4"
    >ГНЦ НИИАР</text>
  <% end %>
</svg>
