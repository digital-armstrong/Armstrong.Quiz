<!DOCTYPE html>
<html data-theme="lofi">
  <head>
    <title><%= content_for(:title) || "Admin — Armstrong Quiz" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartkick"></script>
  </head>
  <body class="min-h-screen bg-base-200">
    <% if notice.present? %>
      <p class="notice alert alert-info rounded-none mb-0"><%= notice %></p>
    <% end %>
    <% if alert.present? %>
      <p class="alert alert-warning rounded-none mb-0"><%= alert %></p>
    <% end %>

    <div class="navbar bg-base-100 shadow-lg">
      <div class="navbar-start">
        <%= link_to "Armstrong Quiz Admin", admin_root_path, class: "btn btn-ghost text-xl" %>
      </div>
      <div class="navbar-end gap-2">
        <% if current_user.admin? %>
          <%= link_to t("admin.nav.users"), admin_users_path, class: "btn btn-ghost btn-sm" %>
          <%= link_to t("admin.nav.categories"), admin_categories_path, class: "btn btn-ghost btn-sm" %>
          <%= link_to t("admin.nav.questions"), admin_questions_path, class: "btn btn-ghost btn-sm" %>
        <% end %>
        <%= link_to t("admin.nav.results"), admin_results_path, class: "btn btn-ghost btn-sm" %>
        <%= link_to t("admin.nav.evaluations"), admin_evaluation_summaries_path, class: "btn btn-ghost btn-sm" %>
        <%= link_to t("admin.nav.logout"), destroy_user_session_path, data: { turbo_method: :delete }, class: "btn btn-ghost btn-sm" %>
      </div>
    </div>

    <main class="container mx-auto mt-8 px-5 pb-12">
      <%= yield %>
    </main>
  </body>
</html>
