<!DOCTYPE html>
<html data-theme="lofi">
  <head>
    <title><%= content_for(:title) || "Admin — Armstrong Quiz" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <script src="/chart.umd.min.js" data-turbo-track="reload" defer></script>
    <script src="/chartkick.js" data-turbo-track="reload" defer></script>
  </head>
  <body class="min-h-screen bg-base-200">
    <div class="navbar fixed top-0 left-0 right-0 z-50 bg-base-100 shadow-lg">
      <div class="navbar-start">
        <%= link_to admin_root_path, class: "btn btn-ghost text-xl font-bold gap-1" do %>
          <span class="font-extrabold">ARMStrong</span>
          <span class="text-primary">:</span>
          <span>Quiz</span>
          <span class="text-primary">:</span>
          <span>Admin</span>
        <% end %>
      </div>
      <div class="navbar-end gap-2">
        <%= link_to t("admin.nav.public_site"), root_path, class: "btn btn-ghost btn-sm" %>
        <% if current_user.admin? %>
          <div class="dropdown dropdown-end">
            <div tabindex="0" role="button" class="btn btn-ghost btn-sm"><%= t("admin.nav.management") %></div>
            <ul tabindex="0" class="dropdown-content menu bg-base-100 rounded-box z-[1] w-52 p-2 shadow">
              <li><%= link_to t("admin.nav.sections"), admin_sections_path %></li>
              <li><%= link_to t("admin.nav.categories"), admin_categories_path %></li>
              <li><%= link_to t("admin.nav.questions"), admin_questions_path %></li>
              <li><%= link_to t("admin.nav.users"), admin_users_path %></li>
            </ul>
          </div>
        <% end %>
        <div class="dropdown dropdown-end">
          <div tabindex="0" role="button" class="btn btn-ghost btn-sm"><%= t("admin.nav.results") %></div>
          <ul tabindex="0" class="dropdown-content menu bg-base-100 rounded-box z-[1] w-52 p-2 shadow">
            <li><%= link_to t("admin.nav.results"), admin_results_path %></li>
            <li><%= link_to t("admin.nav.evaluations"), admin_evaluation_summaries_path %></li>
          </ul>
        </div>
        <%= link_to t("admin.nav.logout"), destroy_user_session_path, data: { turbo_method: :delete }, class: "btn btn-ghost btn-sm" %>
      </div>
    </div>

    <main class="container mx-auto mt-8 px-5 pt-16 pb-12">
      <%= yield %>
    </main>
    <%= render "shared/toast_flash" %>
  </body>
</html>
